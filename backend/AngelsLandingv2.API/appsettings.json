{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FrontendUrl": "http://localhost:3000",
  "ConnectionStrings": {
    "LighthouseConnection": "Data Source=AngelsLandingv2.sqlite"
  },
  "Supabase": {
    "UseSessionPooler": false,
    "AwsRegion": ""
  },
  "AuthCookies": {
    "Mode": "auto",
    "RequireHttps": true
  },
  "GenerateDefaultIdentityAdmin": {
    "Email": "admin@angelslanding.local",
    "Password": "SET_IN_APPSETTINGS_DEVELOPMENT_OR_ENV"
  }
}
